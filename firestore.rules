rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fonctions utilitaires
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidString(value, maxLength) {
      return value is string &&
        value.size() > 0 &&
        value.size() <= maxLength;
    }

    function isValidEmail(email) {
      return email is string &&
        email.matches('^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$');
    }

    function isValidTimestamp(value) {
      return value is timestamp;
    }

    // Collection: admins - Accès uniquement pour les admins
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Géré uniquement via Admin SDK
    }

    // Collection: messages (contact form)
    match /messages/{messageId} {
      allow create: if
        isValidString(request.resource.data.name, 100) &&
        isValidEmail(request.resource.data.email) &&
        isValidString(request.resource.data.subject, 200) &&
        isValidString(request.resource.data.message, 5000) &&
        isValidTimestamp(request.time);

      allow read: if isAdmin();
      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt']);
      allow delete: if isAdmin();
    }

    // Collection: quotes (demandes de devis)
    match /quotes/{quoteId} {
      allow create: if
        isValidString(request.resource.data.name, 100) &&
        isValidEmail(request.resource.data.email) &&
        isValidString(request.resource.data.service, 50) &&
        isValidString(request.resource.data.description, 10000);

      allow read: if isAdmin();
      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'adminNotes']);
      allow delete: if isAdmin();
    }

    // Collection: bookings (réservations)
    match /bookings/{bookingId} {
      allow create: if
        isValidString(request.resource.data.clientName, 100) &&
        isValidEmail(request.resource.data.clientEmail) &&
        isValidString(request.resource.data.serviceType, 50);

      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.clientEmail == request.auth.token.email);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Collection: newsletter_subscribers
    match /newsletter_subscribers/{subscriberId} {
      allow create: if
        isValidEmail(request.resource.data.email) &&
        !exists(/databases/$(database)/documents/newsletter_subscribers/$(request.resource.data.email));

      allow read: if isAdmin();
      allow delete: if isAdmin();
      allow update: if false;
    }

    // Collection: properties (immobilier)
    match /properties/{propertyId} {
      allow read: if true; // Public
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Collection: vehicles (transport)
    match /vehicles/{vehicleId} {
      allow read: if true; // Public
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Collection: trainings (formations)
    match /trainings/{trainingId} {
      allow read: if true; // Public
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Collection: blog_posts
    match /blog_posts/{postId} {
      allow read: if true; // Public
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Collection: blog_categories
    match /blog_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection: site_settings
    match /site_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection: activity_logs (logs admin)
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
